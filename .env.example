# Для docker-compose.yml в корне репозитория (Dokploy Compose)
# Полный список — new/.env.example

VK_TOKEN=ваш_токен_сообщества_vk
MONGO_URI=mongodb://user:pass@host:27017
MONGO_DB=ras
MONGO_COLLECTION=sessions
VK_APP_SECRET=защищённый_ключ_мини_приложения
VK_APP_ID=12345678
PORT=3000
MINIAPP_ENABLED=1
MINIAPP_HOST=0.0.0.0
MINIAPP_ALLOW_UNSIGNED=0
UNIVERSITY_TYPE=T
EIOS_ENCRYPTION_KEY=
