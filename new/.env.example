# Скопируйте в .env (Dokploy → Environment) и заполните значения

# === Обязательно ===
VK_TOKEN=ваш_токен_сообщества_vk

MONGO_URI=mongodb://user:pass@host:27017
MONGO_DB=ras
MONGO_COLLECTION=sessions

# === VK Mini App (HTTPS-домен в настройках приложения VK) ===
VK_APP_SECRET=защищённый_ключ_мини_приложения
VK_APP_ID=12345678

# Порт HTTP внутри контейнера (в Dokploy укажите тот же в Ports)
PORT=3000
# MINIAPP_PORT=3000

# === Опционально ===
UNIVERSITY_TYPE=T
DGTU_API_TOKEN=

# Доп. авторизация ЭИОС (ДГТУ), Fernet-ключ:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EIOS_ENCRYPTION_KEY=
MONGO_EIOS_COLLECTION=eios_credentials

MINIAPP_ENABLED=1
MINIAPP_HOST=0.0.0.0
MINIAPP_ALLOW_UNSIGNED=0
